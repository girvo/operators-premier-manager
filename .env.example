TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
SESSION_DRIVER=cookie
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3333/auth/discord/callback

HENRIK_API_KEY=
# Max Henrik API requests per minute. Defaults to 30 (free tier).
# Raise to match your key's tier (e.g. 60 for basic, 90 for advanced).
HENRIK_RPM=
# Your Premier team name as it appears in Henrik responses (case-insensitive).
# Used to identify "our team" when backfilling matches via UUID, since the
# v4 single-match endpoint returns empty player names for Premier matches.
# Defaults to "OPERATORS".
PREMIER_TEAM_NAME=

# Discord Webhook for Match Notifications
DISCORD_WEBHOOK_URL=

# Discord bot token for direct DM nudges
DISCORD_BOT_TOKEN=

# Optional but strongly recommended for Discord DM links.
# If unset, links are generated as relative paths (won't open correctly from Discord).
# Example: https://operators.example.com
APP_URL=
